<Window x:Class="DukkanDepo.Presentation.Views.SummaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Özet Rapor"
        Height="480"
        Width="760"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ApplicationPageBackgroundThemeBrush}"
        TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Window.Resources>
        <Style TargetType="Control">
            <Setter Property="FontSize" Value="{DynamicResource AppFontSize}" />
        </Style>

        <Style x:Key="SummaryCard" TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="8" />
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
        </Style>

        <Style x:Key="SummaryTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="Opacity" Value="0.85" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="SummaryValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Özet Rapor"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="8,0,0,16" />

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">

            <UniformGrid Columns="2">

                <Border Style="{StaticResource SummaryCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SummaryTitle}"
                                   Text="Toplam Adet" />
                        <TextBlock Style="{StaticResource SummaryValue}"
                                   Text="{Binding ToplamAdet, StringFormat={}{0:N0}}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SummaryCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SummaryTitle}"
                                   Text="Ürün Çeşidi" />
                        <TextBlock Style="{StaticResource SummaryValue}"
                                   Text="{Binding UrunCesidi, StringFormat={}{0:N0}}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SummaryCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SummaryTitle}"
                                   Text="Toplam Tutar" />
                        <TextBlock Style="{StaticResource SummaryValue}"
                                   Text="{Binding ToplamTutar, StringFormat={}{0:N2} ₺}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SummaryCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SummaryTitle}"
                                   Text="Toplam İskontolu Tutar" />
                        <TextBlock Style="{StaticResource SummaryValue}"
                                   Text="{Binding ToplamIskontoluTutar, StringFormat={}{0:N2} ₺}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SummaryCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SummaryTitle}"
                                   Text="Son 30 Gün Tutar" />
                        <TextBlock Style="{StaticResource SummaryValue}"
                                   Text="{Binding Son30GunTutar, StringFormat={}{0:N2} ₺}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SummaryCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SummaryTitle}"
                                   Text="Son 7 Gün İskontolu Tutar" />
                        <TextBlock Style="{StaticResource SummaryValue}"
                                   Text="{Binding Son7GunIskontoluTutar, StringFormat={}{0:N2} ₺}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SummaryCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SummaryTitle}"
                                   Text="En Çok Adetli Ürün" />
                        <TextBlock Style="{StaticResource SummaryValue}"
                                   FontSize="17"
                                   Text="{Binding EnCokAdetKodModel}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SummaryCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SummaryTitle}"
                                   Text="Ortalama Marj" />
                        <TextBlock Style="{StaticResource SummaryValue}"
                                   Text="{Binding OrtalamaKarMarji, StringFormat={}{0:N2}%}" />
                    </StackPanel>
                </Border>

            </UniformGrid>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,8,0">

            <Button Content="Kapat"
                    Width="110"
                    Height="34"
                    Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>