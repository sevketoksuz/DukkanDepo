<Window x:Class="DukkanDepo.Presentation.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dükkan Depo - Başlangıç"
        Height="380"
        Width="560"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="Control">
            <Setter Property="FontSize" Value="{DynamicResource AppFontSize}" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="480">

            <TextBlock Text="Hangi tabloyu açmak istiyorsun?"
                       FontSize="18"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16" />

            <WrapPanel HorizontalAlignment="Center">
                <Button Width="200"
                        Height="56"
                        Margin="0,0,8,0"
                        Content="Yazlık Ürünler"
                        Command="{Binding OpenYazlikCommand}" />

                <Button Width="200"
                        Height="56"
                        Content="Kışlık Ürünler"
                        Command="{Binding OpenKislikCommand}" />
            </WrapPanel>

            <Separator Margin="0,16,0,12" />

            <WrapPanel HorizontalAlignment="Center">
                <Button Width="200"
                        Height="36"
                        Content="Görünüm"
                        Command="{Binding OpenAppearanceCommand}" />

                <Button Width="200"
                        Height="36"
                        Content="Yedek Al"
                        Command="{Binding BackupCommand}"
                        Margin="8,0,0,0" />
            </WrapPanel>

            <WrapPanel HorizontalAlignment="Center"
                       Margin="0,8,0,0">

                <Button Width="200"
                        Height="36"
                        Content="Yedekten Yükle"
                        Command="{Binding RestoreCommand}" />
            </WrapPanel>
        </StackPanel>

        <TextBlock Grid.Row="1"
                   HorizontalAlignment="Right"
                   Opacity="0.6"
                   Text="DukkanDepo • Launcher" />
    </Grid>
</Window>